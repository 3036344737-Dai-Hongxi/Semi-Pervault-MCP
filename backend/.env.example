# LLM
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
VOICECALL_GLM_API_KEY=your-zhipu-glm-api-key
VOICECALL_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VOICECALL_GLM_REALTIME_MODEL=glm-realtime
VOICECALL_GLM_VOICE=tongtong
VOICECALL_GLM_INPUT_AUDIO_FORMAT=pcm16
VOICECALL_GLM_OUTPUT_AUDIO_FORMAT=pcm
VOICE_V2_ENABLED=0
VOICE_V2_VOLC_AK=
VOICE_V2_VOLC_SK=
VOICE_V2_VOLC_RTC_APP_ID=
# 当前 Phase 1 prepare 链路不依赖 RTC AppKey；保留为可选位，供后续 provider 接入差异使用
VOICE_V2_VOLC_RTC_APP_KEY=
VOICE_V2_VOLC_VOICE_CHAT_CONFIG_JSON=
VOICE_V2_VOLC_OPENAPI_REGION=cn-north-1
VOICE_V2_VOLC_OPENAPI_HOST=rtc.volcengineapi.com
VOICE_V2_VOLC_OPENAPI_TIMEOUT_SECONDS=10
VOICE_V2_VOLC_ROOM_PREFIX=pv-room
VOICE_V2_VOLC_TASK_PREFIX=pv-task
VOICE_V2_SESSION_TTL_SECONDS=300

# Embedding
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDING_DIM=768

# 服务鉴权（API_KEY 作为登录密码，SESSION_SECRET 用于签名 cookie）
AUTH_PASSWORD=your-custom-api-key
API_KEY=your-custom-api-key
SESSION_SECRET=your-random-secret-at-least-32-chars
AUTH_LOGIN_RATE_LIMIT=5/minute
ENABLE_SENSITIVE_DEBUG_LOGS=0
# HTTPS 生产部署时设为 1，本地开发保持 0
SECURE_COOKIES=0

# CORS 白名单（逗号分隔，未配置时默认 http://localhost:3000）
# 示例（本地 + Tailscale）：http://localhost:3000,http://100.64.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000

# 定时任务开关（0=关闭，1=开启）
CONSOLIDATION_SCHEDULER_ENABLED=1
WEIGHT_DECAY_SCHEDULER_ENABLED=1
SLEEP_AGENT_ENABLED=1
SLEEP_AGENT_INTERVAL_SECONDS=86400
SLEEP_AGENT_STARTUP_DELAY_SECONDS=300
SLEEP_AGENT_LLM_TIMEOUT_SECONDS=60
SLEEP_AGENT_LLM_CONCURRENCY=3
