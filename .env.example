# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Backend ===
DATABASE_URL=sqlite:///./data.db
AUTH_PASSWORD=your-secret-key
API_KEY=your-secret-key
SESSION_SECRET=your-random-secret-at-least-32-chars
AUTH_LOGIN_RATE_LIMIT=5/minute
ENABLE_SENSITIVE_DEBUG_LOGS=0
OPENAI_API_KEY=sk-your-key-here
VOICECALL_REALTIME_MODEL=gpt-realtime
VOICECALL_REALTIME_VOICE=marin
VOICECALL_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICECALL_REALTIME_TRANSCRIPTION_LANGUAGE=zh
ALLOWED_ORIGINS=http://localhost:3000

# === LLM Settings ===
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.7
